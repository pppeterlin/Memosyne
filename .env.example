# ── Memosyne Environment Variables ──

# Ollama host (local LLM backend)
# Default: http://127.0.0.1:11434
# When using Docker Compose with the local-llm profile, set to: http://ollama:11434
OLLAMA_HOST=http://127.0.0.1:11434

# Cloud LLM API key (optional, only needed for --backend cloud)
# Currently supports Google Gemini. Get your key at: https://aistudio.google.com/apikey
LLM_API_KEY=your_api_key_here
