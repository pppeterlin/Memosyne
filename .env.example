# ── Memosyne Environment Variables ──

# Ollama host (local LLM backend)
# Default: http://127.0.0.1:11434
# When using Docker Compose with the local-llm profile, set to: http://ollama:11434
OLLAMA_HOST=http://127.0.0.1:11434

# Optional private artifact overrides.
# Keep real machine-specific paths in ignored local files, not public docs.
# MEMOSYNE_VAULT_DIR=Personal_Brain_DB/_vault
# MEMOSYNE_ARTIFACT_DIR=Personal_Brain_DB/_vault

# Embedding model runtime.
# Default is local-first/offline: use cached Hugging Face models and skip network checks.
# Set to 0 only when bootstrapping a fresh machine that needs to download the model.
MEMOSYNE_HF_OFFLINE=1

# LLM provider selection.
# Default provider resolution is model-name based; set this only when forcing a backend.
# LLM_PROVIDER=ollama

# OpenRouter backend (optional).
# OPENROUTER_API_KEY=your_openrouter_key_here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenAI-compatible proxy backend (optional).
# PROXY_API_KEY=your_proxy_key_here
# PROXY_BASE_URL=http://localhost:3000/claude-kiro-oauth/v1

# Experimental retrieval tuning. Leave at 1.0 unless evaluating.
# CHAT_CATEGORY_KNOWLEDGE_PENALTY=1.0
